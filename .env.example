# Discord bot public
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
GUILD_ID=

# Dashboard Railway
PUBLIC_URL=https://ton-dashboard.up.railway.app
DASHBOARD_URL=https://ton-dashboard.up.railway.app
NEXT_PUBLIC_BASE_URL=https://ton-dashboard.up.railway.app
PORT=3000

# Sécurité obligatoire
SECRET_KEY=change_me_secret_long_32_chars_minimum
SESSION_SECRET=change_me_session_secret_32_chars_minimum
ENCRYPTION_SECRET=change_me_encryption_secret_32_chars_minimum

# Nitrado global optionnel. Pour un bot public, les clients connectent leur token depuis le dashboard.
NITRADO_TOKEN=

# IA OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# GitHub API optionnel
GITHUB_TOKEN=
GITHUB_REPO=znationcmd/extinction-plus-plus

# Base de données locale / fallback
DATABASE_PATH=shared/database.json
BOT_DATABASE_PATH=../shared/database.json

# PostgreSQL Railway optionnel pour production
DATABASE_URL=

# Production SaaS
DATABASE_URL=postgresql://user:password@host:port/db
PGSSLMODE=require
SESSION_SECRET=change-moi-long-secret
ENCRYPTION_SECRET=change-moi-long-secret-chiffrement
DASHBOARD_URL=https://ton-dashboard.up.railway.app
NEXT_PUBLIC_BASE_URL=https://ton-dashboard.up.railway.app
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GITHUB_TOKEN=
GITHUB_REPO=znationcmd/extinction-plus-plus
